<!DOCTYPE html>
<html lang="en">
<head>
    <title>Manufacturing Database</title>
    <%view stylesheet %>
</head>
<body>
    <%view navbar %>

    <main id="main-content">
    <%c++ 
    bool hasWarning = false;
    std::string warningMessage;
    try {
        warningMessage = @@.get<std::string>("warning");
        hasWarning = !warningMessage.empty();
    } catch(...) {
        // No warning message found, ignore
    }
    
    if (hasWarning) { 
    %>
    <div class="warning-block" role="alert">
        <%c++ $$ << warningMessage; %>
    </div>
    <%c++ } %>

    <div class="page-header">
        <h1>Manufacturing Database</h1>
        <button id="exportCsv" class="export-btn">Export to CSV</button>
    </div>
    
    <div class="toggle-container">
        <label class="toggle-switch">
            <input type="checkbox" id="auto-refresh" checked aria-label="Auto Refresh">
            <span class="toggle-slider"></span>
        </label>
        <label for="auto-refresh">Auto Refresh</label>
        <span id="refresh-status" aria-live="polite">(Enabled - refreshing every 5s)</span>
    </div>
    
    <div id="error-container" aria-live="polite"></div>
    
    <div class="table-container" id="manu-table-container">
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p>Loading manufacturing data&hellip;</p>
        </div>
    </div>
    <div id="pagination-controls" class="pagination-controls" style="display:none;" aria-live="polite"></div>

    <script>
        // Prevent stored XSS by escaping untrusted data before HTML insertion
        function escapeHtml(str) {
            if (str === null || str === undefined) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // Function to format security field values with accessibility
        function formatSecurityField(value) {
            if (value === null || value === undefined || value === '') {
                return '<span class="security-unknown" aria-label="Unknown" title="Unknown">?</span>';
            } else if (value === '1') {
                return '<span class="security-enabled" aria-label="Yes" title="Yes">✓</span>';
            } else if (value === '0') {
                return '<span class="security-disabled" aria-label="No" title="No">✗</span>';
            } else {
                return '<span class="security-unknown" aria-label="Unknown" title="Unknown">?</span>';
            }
        }

        // Scroll indicator state -- kept outside the function to avoid
        // accumulating listeners and timeouts on every refresh cycle.
        let scrollIndicatorTimeout = null;
        let scrollIndicatorShown = false;
        
        function handleScrollHide() {
            const ind = document.querySelector('.scroll-indicator');
            if (ind) ind.style.display = 'none';
            scrollIndicatorShown = false;
            if (scrollIndicatorTimeout) { clearTimeout(scrollIndicatorTimeout); scrollIndicatorTimeout = null; }
        }
        
        function updateScrollIndicator() {
            const container = document.getElementById('manu-table-container');
            if (!container) return;
            
            // Ensure the indicator element exists (innerHTML destroys it each cycle)
            let indicator = container.querySelector('.scroll-indicator');
            if (!indicator) {
                indicator = document.createElement('div');
                indicator.className = 'scroll-indicator';
                indicator.textContent = 'Scroll to see more';
                container.appendChild(indicator);
            }
            
            if (container.scrollWidth > container.clientWidth) {
                if (!scrollIndicatorShown) {
                    indicator.style.display = 'block';
                    scrollIndicatorShown = true;
                    
                    container.addEventListener('scroll', handleScrollHide, { once: true });
                    
                    if (scrollIndicatorTimeout) clearTimeout(scrollIndicatorTimeout);
                    scrollIndicatorTimeout = setTimeout(handleScrollHide, 5000);
                }
            } else {
                indicator.style.display = 'none';
                scrollIndicatorShown = false;
            }
        }
        
        // Format bytes to human-readable size
        function formatBytes(bytes, decimals = 2) {
            if (bytes === 0 || isNaN(parseInt(bytes))) return '0 Bytes';
            
            const k = 1024;
            const sizes = ['Bytes', 'KiB', 'MiB', 'GiB', 'TiB', 'PiB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            
            return parseFloat((bytes / Math.pow(k, i)).toFixed(decimals)) + ' ' + sizes[i];
        }
        
        // Apply human-readable sizes to eMMC size cells
        function applyEmmcSizeTooltips() {
            const emmcCells = document.querySelectorAll('.emmc-size');
            emmcCells.forEach(cell => {
                const sizeInBytes = cell.getAttribute('data-size');
                const humanSize = formatBytes(parseInt(sizeInBytes));
                cell.setAttribute('title', humanSize);
            });
        }
        
        // Pagination state
        let allData = [];
        let currentPage = 1;
        let pageSize = 50;
        const COLUMN_COUNT = 22;
        
        function totalPages() {
            return Math.max(1, Math.ceil(allData.length / pageSize));
        }
        
        function renderCurrentPage() {
            const start = (currentPage - 1) * pageSize;
            const pageData = allData.slice(start, start + pageSize);
            
            let tableHtml = `
                <table id="manufacturingTable">
                    <caption class="sr-only">Manufacturing database showing provisioned device information</caption>
                    <thead>
                        <tr>
                            <th scope="col">Provision Time</th>
                            <th scope="col">ID</th>
                            <th scope="col">Board</th>
                            <th scope="col">Serial</th>
                            <th scope="col">Ethernet MAC</th>
                            <th scope="col">WiFi MAC</th>
                            <th scope="col">Bluetooth MAC</th>
                            <th scope="col">eMMC Size</th>
                            <th scope="col">eMMC CID</th>
                            <th scope="col">RPi DUID</th>
                            <th scope="col">Revision</th>
                            <th scope="col">Processor</th>
                            <th scope="col">Memory</th>
                            <th scope="col">Manufacturer</th>
                            <th scope="col">Secure</th>
                            <th scope="col">JTAG Locked</th>
                            <th scope="col">EEPROM WP</th>
                            <th scope="col">Pubkey Prog.</th>
                            <th scope="col">Devkey Revoked</th>
                            <th scope="col">Signed Boot</th>
                            <th scope="col">OS Image Filename</th>
                            <th scope="col">OS Image SHA256</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
            
            if (pageData.length > 0) {
                pageData.forEach(device => {
                    tableHtml += `
                        <tr>
                            <td>${escapeHtml(device.provision_ts)}</td>
                            <td>${escapeHtml(device.id)}</td>
                            <td>${escapeHtml(device.boardname)}</td>
                            <td>${escapeHtml(device.serial)}</td>
                            <td>${escapeHtml(device.eth_mac)}</td>
                            <td>${escapeHtml(device.wifi_mac)}</td>
                            <td>${escapeHtml(device.bt_mac)}</td>
                            <td class="emmc-size" data-size="${escapeHtml(device.mmc_size)}">${escapeHtml(device.mmc_size)}</td>
                            <td>${escapeHtml(device.mmc_cid)}</td>
                            <td>${escapeHtml(device.rpi_duid)}</td>
                            <td>${escapeHtml(device.board_revision)}</td>
                            <td>${escapeHtml(device.processor)}</td>
                            <td>${escapeHtml(device.memory)}</td>
                            <td>${escapeHtml(device.manufacturer)}</td>
                            <td>${escapeHtml(device.secure)}</td>
                            <td class="security-field">${formatSecurityField(device.jtag_locked)}</td>
                            <td class="security-field">${formatSecurityField(device.eeprom_write_protected)}</td>
                            <td class="security-field">${formatSecurityField(device.pubkey_programmed)}</td>
                            <td class="security-field">${formatSecurityField(device.devkey_revoked)}</td>
                            <td class="security-field">${formatSecurityField(device.signed_boot_enabled)}</td>
                            <td>${escapeHtml(device.os_image_filename)}</td>
                            <td style="font-family: monospace;">${escapeHtml(device.os_image_sha256)}</td>
                        </tr>
                    `;
                });
            } else {
                tableHtml += `
                    <tr>
                        <td colspan="${COLUMN_COUNT}" class="no-devices">No manufacturing data available</td>
                    </tr>
                `;
            }
            
            tableHtml += `
                    </tbody>
                </table>
            `;
            
            // Preserve scroll position across the table rebuild
            const container = document.getElementById('manu-table-container');
            const prevScrollTop = container.scrollTop;
            const prevScrollLeft = container.scrollLeft;
            
            container.innerHTML = tableHtml;
            
            container.scrollTop = prevScrollTop;
            container.scrollLeft = prevScrollLeft;
            
            applyEmmcSizeTooltips();
            updateScrollIndicator();
            renderPaginationControls();
        }
        
        function renderPaginationControls() {
            const total = allData.length;
            const pages = totalPages();
            const controlsEl = document.getElementById('pagination-controls');
            
            if (total === 0) {
                controlsEl.style.display = 'none';
                return;
            }
            controlsEl.style.display = 'flex';
            
            const start = (currentPage - 1) * pageSize + 1;
            const end = Math.min(currentPage * pageSize, total);
            
            let html = '<span class="page-info">Showing ' + start + '–' + end + ' of ' + total + ' devices</span>';
            html += '<div class="page-buttons">';
            html += '<button id="pg-prev" ' + (currentPage <= 1 ? 'disabled' : '') + '>&laquo; Prev</button>';
            
            // Show a window of page buttons around the current page
            const maxButtons = 7;
            let rangeStart = Math.max(1, currentPage - Math.floor(maxButtons / 2));
            let rangeEnd = Math.min(pages, rangeStart + maxButtons - 1);
            if (rangeEnd - rangeStart < maxButtons - 1) {
                rangeStart = Math.max(1, rangeEnd - maxButtons + 1);
            }
            
            if (rangeStart > 1) {
                html += '<button class="pg-goto" data-page="1">1</button>';
                if (rangeStart > 2) html += '<span class="page-info">&hellip;</span>';
            }
            for (let p = rangeStart; p <= rangeEnd; p++) {
                html += '<button class="pg-goto' + (p === currentPage ? ' active-page' : '') + '" data-page="' + p + '">' + p + '</button>';
            }
            if (rangeEnd < pages) {
                if (rangeEnd < pages - 1) html += '<span class="page-info">&hellip;</span>';
                html += '<button class="pg-goto" data-page="' + pages + '">' + pages + '</button>';
            }
            
            html += '<button id="pg-next" ' + (currentPage >= pages ? 'disabled' : '') + '>Next &raquo;</button>';
            html += '</div>';
            html += '<label class="page-info">Per page: <select id="pg-size">';
            [25, 50, 100, 250].forEach(s => {
                html += '<option value="' + s + '"' + (s === pageSize ? ' selected' : '') + '>' + s + '</option>';
            });
            html += '</select></label>';
            
            controlsEl.innerHTML = html;
            
            // Bind events
            const prevBtn = document.getElementById('pg-prev');
            const nextBtn = document.getElementById('pg-next');
            if (prevBtn) prevBtn.addEventListener('click', () => { currentPage--; renderCurrentPage(); });
            if (nextBtn) nextBtn.addEventListener('click', () => { currentPage++; renderCurrentPage(); });
            controlsEl.querySelectorAll('.pg-goto').forEach(btn => {
                btn.addEventListener('click', () => { currentPage = parseInt(btn.dataset.page); renderCurrentPage(); });
            });
            const sizeSelect = document.getElementById('pg-size');
            if (sizeSelect) sizeSelect.addEventListener('change', () => {
                pageSize = parseInt(sizeSelect.value);
                currentPage = 1;
                renderCurrentPage();
            });
        }
        
        // Fetch data from API and re-render
        async function refreshManufacturingTable() {
            try {
                const response = await fetch('/api/v2/manufacturing');
                
                if (!response.ok) {
                    throw new Error(`Failed to fetch data: ${response.status} ${response.statusText}`);
                }
                
                const data = await response.json();
                allData = Array.isArray(data) ? data : [];
                
                // Clamp current page if the dataset shrank
                if (currentPage > totalPages()) currentPage = totalPages();
                
                renderCurrentPage();
                
                // Clear any previous error
                document.getElementById('error-container').innerHTML = '';
                
                return true;
            } catch (error) {
                console.error('Error fetching manufacturing data:', error);
                
                // Remove loading spinner if this is the first load
                const loader = document.querySelector('#manu-table-container .loading-container');
                if (loader) loader.remove();
                
                document.getElementById('error-container').innerHTML = `
                    <div class="error-message">
                        <strong>Error loading data:</strong> ${escapeHtml(error.message) || 'Failed to fetch manufacturing data'}
                    </div>
                `;
                
                return false;
            }
        }
        
        // Export ALL data to CSV (not just the current page)
        document.getElementById('exportCsv').addEventListener('click', function() {
            if (!allData || allData.length === 0) return;
            
            function csvEscape(val) {
                const s = (val === null || val === undefined) ? '' : String(val);
                return '"' + s.replace(/"/g, '""') + '"';
            }
            
            function securityLabel(val) {
                if (val === '1') return 'Yes';
                if (val === '0') return 'No';
                return 'Unknown';
            }
            
            const headers = [
                'Provision Time','ID','Board','Serial','Ethernet MAC','WiFi MAC',
                'Bluetooth MAC','eMMC Size','eMMC CID','RPi DUID','Revision',
                'Processor','Memory','Manufacturer','Secure','JTAG Locked',
                'EEPROM WP','Pubkey Prog.','Devkey Revoked','Signed Boot',
                'OS Image Filename','OS Image SHA256'
            ];
            
            const rows = [headers.map(csvEscape).join(',')];
            allData.forEach(d => {
                rows.push([
                    csvEscape(d.provision_ts), csvEscape(d.id), csvEscape(d.boardname),
                    csvEscape(d.serial), csvEscape(d.eth_mac), csvEscape(d.wifi_mac),
                    csvEscape(d.bt_mac), csvEscape(d.mmc_size), csvEscape(d.mmc_cid),
                    csvEscape(d.rpi_duid), csvEscape(d.board_revision), csvEscape(d.processor),
                    csvEscape(d.memory), csvEscape(d.manufacturer), csvEscape(d.secure),
                    csvEscape(securityLabel(d.jtag_locked)),
                    csvEscape(securityLabel(d.eeprom_write_protected)),
                    csvEscape(securityLabel(d.pubkey_programmed)),
                    csvEscape(securityLabel(d.devkey_revoked)),
                    csvEscape(securityLabel(d.signed_boot_enabled)),
                    csvEscape(d.os_image_filename), csvEscape(d.os_image_sha256)
                ].join(','));
            });
            
            const blob = new Blob([rows.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = 'manufacturing_data_' + new Date().toISOString().split('T')[0] + '.csv';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        });

        // Auto-refresh functionality
        let refreshInterval;
        const refreshToggle = document.getElementById('auto-refresh');
        const refreshStatus = document.getElementById('refresh-status');
        
        // Load data initially
        document.addEventListener('DOMContentLoaded', function() {
            // Do initial load
            refreshManufacturingTable();
            
            // Initialize auto-refresh based on toggle state
            if (refreshToggle.checked) {
                startRefresh();
            }
        });
        
        // Function to start the refresh interval
        function startRefresh() {
            // Use 5 seconds refresh rate to reduce server load
            refreshInterval = setInterval(refreshManufacturingTable, 5000);
            refreshStatus.textContent = '(Enabled - refreshing every 5s)';
        }
        
        // Function to stop the refresh interval
        function stopRefresh() {
            clearInterval(refreshInterval);
            refreshStatus.textContent = '(Disabled)';
        }
        
        // Toggle auto-refresh when the checkbox is changed
        refreshToggle.addEventListener('change', function() {
            if (this.checked) {
                startRefresh();
            } else {
                stopRefresh();
            }
        });
        
        // Cleanup when navigating away
        window.addEventListener('beforeunload', () => {
            console.log('Page unloading - cleaning up auto-refresh');
            stopRefresh();
        });
        
        // Also cleanup on page hide (covers more navigation scenarios)
        window.addEventListener('pagehide', () => {
            console.log('Page hidden - cleaning up auto-refresh');
            stopRefresh();
        });
    </script>
    </main>
</body>
</html> 